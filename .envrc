# direnv config. Run `direnv allow` once to authorize this file.
#
# Loads .env (NixOS-only LD_LIBRARY_PATH / TRITON_LIBCUDA_PATH so the bundled
# torch / Triton wheels can find /run/opengl-driver/lib/libcuda.so) and
# activates the uv-managed venv so `python`, `pytest`, etc. resolve to the
# right interpreter without `uv run --env-file .env ...` boilerplate.

dotenv_if_exists .env

if [ -f .venv/bin/activate ]; then
    source .venv/bin/activate
else
    log_status "no .venv yet -- run \`uv sync\` (optionally with --extra dali / --extra bench)"
fi
